<!--
PSEUDOCODE / PLAN (detailed):
1. Detect cause: XLS0419 means the XAML 'clr-namespace:ETABS_Stability' cannot be resolved.
2. Check where the CLR namespace is actually declared:
   - Open the code-behind for this XAML (e.g., MainWindow.xaml.cs or other .cs files).
   - Confirm the C# namespace containing the window/control classes (e.g., "namespace ETABS_Stability" or different).
3. Fix options (choose one appropriate):
   A) If the C# namespace is different, change the XAML namespace to match:
      - Replace xmlns:local="clr-namespace:ETABS_Stability"
        with xmlns:local="clr-namespace:Actual.Cs.Namespace" (use the exact C# namespace).
   B) If the types are in another assembly, include assembly:
      - xmlns:local="clr-namespace:ETABS_Stability;assembly=OtherAssemblyName"
   C) If you do not use the 'local' prefix in this XAML, simply remove the xmlns:local declaration.
4. Additional checks:
   - Ensure the .cs files are included in the project and Build Action = Compile.
   - Ensure the project's RootNamespace (or default namespace) in the .csproj is as expected.
   - Ensure x:Class matches the full CLR namespace + class name in the code-behind.
   - Clean and Rebuild the solution after making changes.
5. If uncertain, provide the namespace line from the code-behind file (the 'namespace ...' line) and the project assembly name; then apply option A or B.
-->

<Window x:Class="ETABS_Stability.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Phần mềm tính toán và thiết kế Ván Khuôn Sàn" Height="900" Width="1300"
        Background="Transparent" ResizeMode="NoResize"
        AllowsTransparency="True" WindowStyle="None" WindowStartupLocation="CenterScreen">

    <!-- NOTE:
         Removed xmlns:local="clr-namespace:ETABS_Stability" because the CLR namespace could not be resolved.
         If your C# files are actually in a different namespace, add or replace the xmlns:local line with:
         - xmlns:local="clr-namespace:Actual.Cs.Namespace"
         OR if types are in another assembly:
         - xmlns:local="clr-namespace:ETABS_Stability;assembly=YourAssemblyName"
         Add the exact C# namespace or assembly name from your project to fix XLS0419.
    -->

    <Border Background="LightSteelBlue" CornerRadius="40" BorderThickness="2" BorderBrush="AliceBlue" Padding="20">
        <Border CornerRadius="40">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="White" Offset="0"/>
                    <GradientStop Color="WhiteSmoke" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="MenuPanel" CornerRadius="20" Background="MidnightBlue" Margin="20" Width="90">
                    <Grid>
                        <Image Source="\Resources\Images\logo.jpg" Width="60" Height="60" Margin="0,650,0,0"/>

                        <StackPanel VerticalAlignment="Top">
                            <ToggleButton x:Name="MenuToggleButton"
                                          Style="{StaticResource MaterialDesignIconForegroundButton}"
                                          ToolTip="Mở rộng menu" HorizontalAlignment="Left" Margin="20,10,0,0">
                                <materialDesign:PackIcon Kind="Menu" Foreground="White" Width="30" Height="30" />
                                <ToggleButton.Triggers>
                                    <EventTrigger RoutedEvent="ToggleButton.Unchecked">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="MenuPanel" Storyboard.TargetProperty="Width" From="200" To="90" Duration="0:0:0.2"/>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="HomeText" Storyboard.TargetProperty="Visibility">
                                                    <DiscreteObjectKeyFrame KeyTime="0:0:0.2" Value="{x:Static Visibility.Collapsed}"/>
                                                </ObjectAnimationUsingKeyFrames>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="DataInputText" Storyboard.TargetProperty="Visibility">
                                                    <DiscreteObjectKeyFrame KeyTime="0:0:0.2" Value="{x:Static Visibility.Collapsed}"/>
                                                </ObjectAnimationUsingKeyFrames>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="CheckText" Storyboard.TargetProperty="Visibility">
                                                    <DiscreteObjectKeyFrame KeyTime="0:0:0.2" Value="{x:Static Visibility.Collapsed}"/>
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                    <EventTrigger RoutedEvent="ToggleButton.Checked">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="MenuPanel" Storyboard.TargetProperty="Width" From="90" To="200" Duration="0:0:0.2"/>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="HomeText" Storyboard.TargetProperty="Visibility">
                                                    <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Visible}"/>
                                                </ObjectAnimationUsingKeyFrames>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="DataInputText" Storyboard.TargetProperty="Visibility">
                                                    <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Visible}"/>
                                                </ObjectAnimationUsingKeyFrames>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="CheckText" Storyboard.TargetProperty="Visibility">
                                                    <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Visible}"/>
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </ToggleButton.Triggers>
                            </ToggleButton>

                            <Separator Height="30" Background="Transparent"/>

                            <Button x:Name="HomeButton" Style="{StaticResource MaterialDesignFlatButton}" HorizontalAlignment="Left" Margin="13,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Home" Width="30" Height="30" Foreground="White" Margin="0,0,10,0"/>
                                    <TextBlock x:Name="HomeText" Text="Trang chủ" Foreground="White" FontSize="14" VerticalAlignment="Center" Visibility="Collapsed" />
                                </StackPanel>
                            </Button>

                            <Button x:Name="Nhapsolieu" Style="{StaticResource MaterialDesignFlatButton}" HorizontalAlignment="Left" Margin="13,10,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="DatabaseEdit" Width="30" Height="30" Foreground="White" Margin="0,0,10,0"/>
                                    <TextBlock x:Name="DataInputText" Text="Thông số ván khuôn" Foreground="White" FontSize="14" VerticalAlignment="Center" Visibility="Collapsed"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="CheckButton" Style="{StaticResource MaterialDesignFlatButton}" HorizontalAlignment="Left" Margin="13,10,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ShieldCheck" Width="30" Height="30" Foreground="White" Margin="0,0,10,0"/>
                                    <TextBlock x:Name="CheckText" Text="Kiểm tra ổn định" Foreground="White" FontSize="14" VerticalAlignment="Center" Visibility="Collapsed"/>
                                </StackPanel>
                            </Button>

                            <StackPanel x:Name="CheckMenu" Visibility="Visible" Margin="25,5,0,0">
                                <Button Style="{StaticResource MaterialDesignFlatButton}" HorizontalAlignment="Left" Height="35">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="FormatLineWeight" Width="20" Height="20" Foreground="White" Margin="0,0,10,0"/>
                                        <TextBlock Text="Độ võng xà gồ" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource MaterialDesignFlatButton}" HorizontalAlignment="Left" Height="35">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="ArrowDownBold" Width="20" Height="20" Foreground="White" Margin="0,0,10,0"/>
                                        <TextBlock Text="Lực nén cây chống" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <Button x:Name="ExportButton" Style="{StaticResource MaterialDesignFlatButton}" HorizontalAlignment="Left" Margin="13,10,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FilePdfBox" Width="30" Height="30" Foreground="White" Margin="3,0,10,0"/>
                                    <TextBlock Text="Xuất thuyết minh" Foreground="White" FontSize="14" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button x:Name="ExitButton" Style="{StaticResource MaterialDesignFlatButton}" HorizontalAlignment="Left" Margin="13,150,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ExitToApp" Width="30" Height="30" Foreground="White" Margin="2,0,10,0"/>
                                    <TextBlock Text="Thoát" Foreground="White" FontSize="14" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Column="1" Margin="20,20,20,20">
                    <Border x:Name="TopMenuPanel" CornerRadius="20" Height="60" VerticalAlignment="Top" Background="White">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                            <Button Style="{StaticResource MaterialDesignRaisedButton}" Background="Green" Height="40" Width="180">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Play" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="CHẠY TÍNH TOÁN" VerticalAlignment="Center" FontSize="14" FontWeight="Bold"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <Grid Margin="0,80,0,0">
                        <Border BorderBrush="MidnightBlue" BorderThickness="3" CornerRadius="10">
                            <Grid>
                                <Image Source="\Resources\Images\huce.jpg" Stretch="Fill" Opacity="0.3">
                                    <Image.Effect>
                                        <BlurEffect Radius="5"/>
                                    </Image.Effect>
                                </Image>

                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="THIẾT KẾ VÁN KHUÔN SÀN" FontSize="50" FontFamily="Impact" 
                                               Foreground="MidnightBlue" HorizontalAlignment="Center"/>

                                    <Border Background="White" CornerRadius="15" Padding="20" Width="500" Height="350" 
                                            Margin="0,20,0,0" BorderBrush="RoyalBlue" BorderThickness="2">
                                        <StackPanel>
                                            <TextBlock Text="Mô hình tính toán" FontWeight="Bold" FontSize="18" Margin="0,0,0,10" Foreground="Black"/>
                                            <Image Source="/Resources/Images/Vankhuon.jpg" Height="250" Stretch="Uniform"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Border>
</Window>
<Window x:Class="ETABS_Stability.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DALTUDTXD_PMTTVKG_0306868_68TH4_Kiet"
        mc:Ignorable="d"
        Title="PHẦN MỀM THIẾT KẾ VÁN KHUÔN SÀN" Height="650" Width="1050"
        Background="SteelBlue" FontFamily="Segoe UI" FontSize="12">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="25"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0" Background="#F3F3F3" Foreground="Black">
            <MenuItem Header="Tệp tin"/>
            <MenuItem Header="Nhập dữ liệu"/>
            <MenuItem Header="Kiểm tra ổn định"/>
            <MenuItem Header="Trợ giúp"/>
        </Menu>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Background="White">
            <Button Content="Tệp" Padding="15,0" Background="Transparent" BorderThickness="0,0,1,0" BorderBrush="#EEE"/>
            <Button Content="Nhập liệu" Padding="15,0" Background="#D6EAF8" BorderThickness="0,0,1,0" BorderBrush="#EEE" FontWeight="Bold"/>
            <Button Content="Tải trọng" Padding="15,0" Background="Transparent" BorderThickness="0,0,1,0" BorderBrush="#EEE"/>
            <Button Content="Kiểm tra" Padding="15,0" Background="Transparent" BorderThickness="0,0,1,0" BorderBrush="#EEE"/>
            <Button Content="Báo cáo" Padding="15,0" Background="Transparent" BorderThickness="0,0,1,0" BorderBrush="#EEE"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Background="#F8F9F9">
            <Button Content="📥 Nhập dữ liệu từ ETABS" Margin="5" Padding="10,5" Background="White" BorderBrush="#D5DBDB"/>
            <Button Content="🔍 Chạy phân tích ổn định" Margin="5" Padding="10,5" Background="White" BorderBrush="#D5DBDB"/>
            <Button Content="📋 Xuất báo cáo kỹ thuật" Margin="5" Padding="10,5" Background="White" BorderBrush="#D5DBDB"/>
        </StackPanel>

        <Grid Grid.Row="3" Margin="15,10" Background="#EBEDEF">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="DimGray" BorderThickness="1" CornerRadius="3" Background="White" Padding="10" Margin="0,0,5,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="35"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="DỮ LIỆU ĐẦU VÀO ETABS" 
                               Foreground="#2E86C1" FontWeight="Bold" 
                               FontSize="14" HorizontalAlignment="Center"/>

                    <Rectangle Grid.Row="1" Fill="#FBFCFC" Stroke="#D5DBDB" StrokeDashArray="4 4"/>
                    <TextBlock Grid.Row="1" Text="[Bảng dữ liệu sẽ hiển thị ở đây]" 
                               VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="Gray"/>
                </Grid>
            </Border>

            <Border Grid.Column="1" BorderBrush="DimGray" BorderThickness="1" CornerRadius="3" Background="White" Padding="10" Margin="5,0,0,0">
                <TextBlock Text="KẾT QUẢ TÍNH TOÁN" Foreground="#2E86C1" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center"/>
            </Border>
        </Grid>

        <StatusBar Grid.Row="4" Background="SteelBlue" Foreground="White">
            <StatusBarItem Content="Sẵn sàng"/>
            <Separator/>
            <StatusBarItem Content="Project: Ván khuôn sàn - SV: Kiệt"/>
        </StatusBar>
    </Grid>
</Window>
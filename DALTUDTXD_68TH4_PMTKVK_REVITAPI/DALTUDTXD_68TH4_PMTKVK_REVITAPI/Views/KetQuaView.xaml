<UserControl x:Class="DALTUDTXD_68TH4_PMTKVK_REVITAPI.Views.KetQuaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DALTUDTXD_68TH4_PMTKVK_REVITAPI.Views"
             xmlns:vm="clr-namespace:DALTUDTXD_68TH4_PMTKVK_REVITAPI.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="550" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance Type=vm:KetQuaViewModel, IsDesignTimeCreatable=False}">
    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="25"/>
                <RowDefinition Height="35"/>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>

            <!-- Menu Hệ Thống -->
            <Menu Grid.Row="0" Background="#F3F3F3" Foreground="Black">
                <MenuItem Header=""/>
            </Menu>

            <!-- Tab Navigation -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Background="White">
                <Button Content="Dữ liệu"     Command="{Binding ChangeTabCommand}" CommandParameter="DuLieuView"  Padding="15,0" Background="White" BorderThickness="0,0,1,0" BorderBrush="#EEE"/>
                <Button Content="Tính toán"   Command="{Binding ChangeTabCommand}" CommandParameter="TinhToanView" Padding="15,0" Background="White" BorderThickness="0,0,1,0" BorderBrush="#EEE"/>
                <Button Content="Thông số"   Command="{Binding ChangeTabCommand}" CommandParameter="ThongSoView"  Padding="15,0" Background="White" BorderThickness="0,0,1,0" BorderBrush="#EEE"/>
                <Button Content="Kết quả"     Command="{Binding ChangeTabCommand}" CommandParameter="KetQuaView"   Padding="15,0" Background="White" BorderThickness="0,0,1,0" BorderBrush="#EEE" FontWeight="Bold"/>
            </StackPanel>

            <!-- Toolbar Action -->
            <Grid Grid.Row="2" Background="#F8F9F9">
                <StackPanel Orientation="Horizontal">
                    <Button Content=" Dựng hình Revit 3D"        Command="{Binding CreateRevitModelCommand}"        Margin="5" Padding="12,5" Background="White" BorderBrush="White" FontWeight="Bold"/>
                    <Button Content=" Thống kê toàn dự án"      Command="{Binding CalculateAllFloorsCommand}"      Margin="5" Padding="12,5" Background="White" BorderBrush="White" FontWeight="Bold"/>
                    <Button Content=" Xuất Excel"               Command="{Binding ExportExcelCommand}"             Margin="5" Padding="12,5" Background="White" BorderBrush="White" FontWeight="Bold"/>
                </StackPanel>
            </Grid>

            <!-- Vùng Hiển Thị Chính -->
            <Grid Grid.Row="3" Margin="15,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Cột Bảng tiên lượng -->
                <Grid Grid.Column="0" Margin="0,0,5,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Bảng tiên lượng cấu kiện chọn -->
                    <Border Grid.Row="0" BorderBrush="#ABB2B9" BorderThickness="1" CornerRadius="3" Background="White" Padding="15" Margin="0,0,0,5">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="BẢNG TIÊN LƯỢNG VẬT TƯ (CÁC SÀN ĐANG CHỌN)" Foreground="#2C3E50" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                            <DataGrid ItemsSource="{Binding MaterialQuantities}" 
                                      AutoGenerateColumns="False" 
                                      CanUserAddRows="False" 
                                      IsReadOnly="True"
                                      Background="White" 
                                      RowHeight="25"
                                      BorderThickness="1" 
                                      BorderBrush="#D5DBDB">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Tên vật tư" Binding="{Binding MaterialName}" Width="2*" />
                                    <DataGridTextColumn Header="Quy cách/Tiết diện" Binding="{Binding Specification}" Width="1.5*" />
                                    <DataGridTextColumn Header="Số lượng" Binding="{Binding Quantity}" Width="0.8*" />
                                    <DataGridTextColumn Header="Đơn vị" Binding="{Binding Unit}" Width="0.8*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>

                    <!-- Danh sách các sàn trong dự án (Dạng Thẻ) -->
                    <Border Grid.Row="1" BorderBrush="#ABB2B9" BorderThickness="1" CornerRadius="3" Background="White" Padding="15" Margin="0,5,0,0">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="DANH SÁCH SÀN TRONG DỰ ÁN" Foreground="#2C3E50" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,5,0">
                                <ItemsControl ItemsSource="{Binding FloorElements}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,10" Background="White" CornerRadius="5">
                                                <Border.Effect>
                                                    <DropShadowEffect Color="#B0B0B0" BlurRadius="6" ShadowDepth="1" Opacity="0.3" Direction="270" />
                                                </Border.Effect>

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="5" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <Border Grid.Column="0" Background="#3498DB" CornerRadius="5,0,0,5" />

                                                    <Grid Grid.Column="1" Margin="15,10">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>

                                                        <DockPanel Grid.Row="0" Margin="0,0,0,8">
                                                            <!-- Nút xem chi tiết -->
                                                            <Button DockPanel.Dock="Right" Content="Chi tiết" 
                                                                    Command="{Binding DataContext.ShowFloorDetailsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    Margin="10,0,0,0" Padding="12,3" Background="#16A085" Foreground="White" BorderBrush="Transparent" FontWeight="Bold" Cursor="Hand" VerticalAlignment="Center"/>

                                                            <!-- ID phần tử -->
                                                            <Border DockPanel.Dock="Right" Background="#F4F6F6" CornerRadius="3" Padding="6,2" VerticalAlignment="Center" Margin="10,0,0,0">
                                                                <TextBlock Text="{Binding ElementId, StringFormat='ID: {0}'}" FontSize="12" Foreground="#7F8C8D" FontWeight="SemiBold" />
                                                            </Border>

                                                            <!-- Tên phần tử -->
                                                            <TextBlock Text="{Binding FamilyTypeName}" FontSize="14" FontWeight="Bold" Foreground="#2C3E50" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                                        </DockPanel>

                                                        <WrapPanel Grid.Row="1" Orientation="Horizontal">
                                                            <StackPanel Orientation="Horizontal" Margin="0,0,20,5">
                                                                <TextBlock Text="Tầng: " Foreground="#7F8C8D" FontSize="12"/>
                                                                <TextBlock Text="{Binding Level}" FontWeight="SemiBold" Foreground="#34495E" FontSize="12"/>
                                                            </StackPanel>

                                                            <StackPanel Orientation="Horizontal" Margin="0,0,20,5">
                                                                <TextBlock Text="Diện tích: " Foreground="#7F8C8D" FontSize="12"/>
                                                                <TextBlock Text="{Binding Area, StringFormat='{}{0:F2} m²'}" FontWeight="SemiBold" Foreground="#34495E" FontSize="12"/>
                                                            </StackPanel>

                                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                                                <TextBlock Text="Chiều dày: " Foreground="#7F8C8D" FontSize="12"/>
                                                                <TextBlock Text="{Binding Thickness, StringFormat='{}{0:F0} mm'}" FontWeight="SemiBold" Foreground="#34495E" FontSize="12"/>
                                                            </StackPanel>
                                                        </WrapPanel>
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Grid>

                <!-- THÔNG SỐ BỐ TRÍ TỐI ƯU -->
                <Border Grid.Column="1" BorderBrush="#ABB2B9" BorderThickness="1" CornerRadius="3" Background="White" Padding="15" Margin="5,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="THÔNG SỐ BỐ TRÍ TỐI ƯU" Foreground="#2C3E50" FontWeight="Bold" FontSize="14" Margin="0,0,0,15"/>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35"/>
                                <RowDefinition Height="35"/>
                                <RowDefinition Height="35"/>
                                <RowDefinition Height="35"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Khoảng cách XG phụ:" VerticalAlignment="Center"/>
                            <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding Joist1Spacing}" IsReadOnly="True" Padding="5,0" VerticalContentAlignment="Center" Margin="2" Background="#F8F9F9"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="mm" Margin="5,0" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="1" Text="Khoảng cách XG chính:" VerticalAlignment="Center"/>
                            <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding Joist2Spacing}" IsReadOnly="True" Padding="5,0" VerticalContentAlignment="Center" Margin="2" Background="#F8F9F9"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="mm" Margin="5,0" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="2" Text="Khoảng cách cây chống:" VerticalAlignment="Center"/>
                            <TextBox   Grid.Row="2" Grid.Column="1" Text="{Binding SupportSpacing}" IsReadOnly="True" Padding="5,0" VerticalContentAlignment="Center" Margin="2" Background="#F8F9F9"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="mm" Margin="5,0" VerticalAlignment="Center"/>
                        </Grid>

                        <Separator Grid.Row="2" Margin="0,15"/>

                        <Button Grid.Row="3" Content="XUẤT THUYẾT MINH PDF (.pdf)" 
                                Command="{Binding ExportPdfCommand}"
                                Height="45" Background="White" Foreground="Black"
                                FontWeight="Bold" Margin="0,10"/>

                        <!-- 2D Floor Plan Preview -->
                        <Border Grid.Row="4" Margin="0,10,0,0" BorderBrush="#D5DBDB" BorderThickness="1" CornerRadius="3" Background="#F8F9F9">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Header cho bản vẽ -->
                                <Border Grid.Row="0" Background="#EAEDED" Padding="8,5" CornerRadius="3,3,0,0" BorderBrush="#D5DBDB" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <TextBlock Text="MẶT BẰNG 2D DỰ ÁN" FontWeight="SemiBold" Foreground="#34495E" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Content="👉 Chọn sàn từ mô hình" 
                                                    Command="{Binding SelectFloorCommand}" 
                                                    Background="#3498DB" Foreground="White" 
                                                    BorderThickness="0" Padding="10,2" FontWeight="Bold" Cursor="Hand" Margin="0,0,5,0"/>
                                            <Button Content="👉 Quét chọn nhiều ô sàn" 
                                                    Command="{Binding SweepSelectFloorCommand}" 
                                                    Background="#3498DB" Foreground="White" 
                                                    BorderThickness="0" Padding="10,2" FontWeight="Bold" Cursor="Hand"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Vùng hiển thị Revit PreviewControl -->
                                <ContentControl Grid.Row="1" Content="{Binding ProjectPreview}" Margin="5"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- Thanh Trạng Thái -->
            <StatusBar Grid.Row="4" Background="#F8F9F9" BorderBrush="#D5DBDB" BorderThickness="0,1,0,0">
                <StatusBarItem Content="Ván khuôn sàn"/>
                <Separator/>
                <StatusBarItem Content="{Binding RevitVersionStatus}"/>
            </StatusBar>
        </Grid>
    </Grid>
</UserControl>
<UserControl x:Class="DALTUDTXD_68TH4_PMTKVK_REVITAPI.Views.ThongSoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DALTUDTXD_68TH4_PMTKVK_REVITAPI.Views"
             xmlns:vm="clr-namespace:DALTUDTXD_68TH4_PMTKVK_REVITAPI.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="550" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance Type=vm:ThongSoViewModel, IsDesignTimeCreatable=False}">
    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="25"/>
                <RowDefinition Height="35"/>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>

            <!-- Menu Hệ Thống -->
            <Menu Grid.Row="0" Background="#F3F3F3" Foreground="Black">
                <MenuItem Header=""/>
            </Menu>
            
            <!-- Tab Navigation -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Background="White">
                <Button Content="Dữ liệu"     Command="{Binding ChangeTabCommand}" CommandParameter="DuLieuView"  Padding="15,0" Background="White" BorderThickness="0,0,1,0" BorderBrush="#EEE"/>
                <Button Content="Tính toán"   Command="{Binding ChangeTabCommand}" CommandParameter="TinhToanView" Padding="15,0" Background="White" BorderThickness="0,0,1,0" BorderBrush="#EEE"/>
                <Button Content="Thông số"   Command="{Binding ChangeTabCommand}" CommandParameter="ThongSoView"  Padding="15,0" Background="White" BorderThickness="0,0,1,0" BorderBrush="#EEE" FontWeight="Bold"/>
                <Button Content="Kết quả"     Command="{Binding ChangeTabCommand}" CommandParameter="KetQuaView"   Padding="15,0" Background="White" BorderThickness="0,0,1,0" BorderBrush="#EEE"/>
            </StackPanel>
            
            <!-- Toolbar Settings -->
            <Grid Grid.Row="2" Background="#F8F9F9">
                <StackPanel Orientation="Horizontal">
                    <Button Content=" Lưu cấu hình"        Command="{Binding SaveSettingsCommand}"        Margin="5" Padding="12,5" Background="White" BorderBrush="White" FontWeight="Bold"/>
                    <Button Content=" Đặt lại mặc định"     Command="{Binding ResetSettingsCommand}"       Margin="5" Padding="12,5" Background="White" BorderBrush="White" FontWeight="Bold"/>
                </StackPanel>
            </Grid>

            <!-- Vùng Hiển Thị Chính -->
            <Grid Grid.Row="3" Margin="15,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="380"/>
                </Grid.ColumnDefinitions>

                <!-- Cấu hình Tiêu chuẩn & Tải trọng -->
                <Border Grid.Column="0" BorderBrush="#ABB2B9" BorderThickness="1" CornerRadius="3" Background="White" Padding="15" Margin="0,0,5,0">
                    <StackPanel>
                        <TextBlock Text="CẤU HÌNH TIÊU CHUẨN &amp; TẢI TRỌNG THIẾT KẾ" Foreground="#2C3E50" FontWeight="Bold" FontSize="14" Margin="0,0,0,15"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35"/>
                                <RowDefinition Height="35"/>
                                <RowDefinition Height="35"/>
                                <RowDefinition Height="35"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Tiêu chuẩn tính toán gỗ:" VerticalAlignment="Center"/>
                            <ComboBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" SelectedIndex="0" VerticalContentAlignment="Center" Margin="2">
                                <ComboBoxItem Content="TCVN 5575:2012"/>
                                <ComboBoxItem Content="EN 1995-1-1 (Eurocode 5)"/>
                                <ComboBoxItem Content="AWC NDS-2018"/>
                            </ComboBox>

                            <TextBlock Grid.Row="1" Text="Tải trọng bản thân ván khuôn:" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding WoodFormworkWeight, TargetNullValue='0.30'}" Padding="5,0" VerticalContentAlignment="Center" Margin="2"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="kN/m²" Margin="5,0" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="2" Text="Tải trọng đổ bê tông tươi:" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding ConcreteWeight, TargetNullValue='25.00'}" Padding="5,0" VerticalContentAlignment="Center" Margin="2"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="kN/m³" Margin="5,0" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="3" Text="Hoạt tải người &amp; thiết bị thi công:" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding ConstructionLiveLoad, TargetNullValue='2.50'}" Padding="5,0" VerticalContentAlignment="Center" Margin="2"/>
                            <TextBlock Grid.Row="3" Grid.Column="2" Text="kN/m²" Margin="5,0" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Hệ số an toàn vật liệu -->
                <Border Grid.Column="1" BorderBrush="#ABB2B9" BorderThickness="1" CornerRadius="3" Background="White" Padding="15" Margin="5,0,0,0">
                    <StackPanel>
                        <TextBlock Text="HỆ SỐ AN TOÀN VÀ HỆ SỐ ĐIỀU CHỈNH" Foreground="#2C3E50" FontWeight="Bold" FontSize="14" Margin="0,0,0,15"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35"/>
                                <RowDefinition Height="35"/>
                                <RowDefinition Height="35"/>
                                <RowDefinition Height="35"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Hệ số tin cậy tải trọng tĩnh (γG):" VerticalAlignment="Center"/>
                            <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding DeadLoadSafetyFactor, TargetNullValue='1.20'}" Padding="5,0" VerticalContentAlignment="Center" Margin="2"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="—" Margin="5,0" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="1" Text="Hệ số tin cậy hoạt tải (γQ):" VerticalAlignment="Center"/>
                            <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding LiveLoadSafetyFactor, TargetNullValue='1.30'}" Padding="5,0" VerticalContentAlignment="Center" Margin="2"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="—" Margin="5,0" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="2" Text="Hệ số điều chỉnh điều kiện ẩm (m_u):" VerticalAlignment="Center"/>
                            <TextBox   Grid.Row="2" Grid.Column="1" Text="{Binding MoistureFactor, TargetNullValue='0.85'}" Padding="5,0" VerticalContentAlignment="Center" Margin="2"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="—" Margin="5,0" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="3" Text="Hệ số điều chỉnh nhiệt độ (m_t):" VerticalAlignment="Center"/>
                            <TextBox   Grid.Row="3" Grid.Column="1" Text="{Binding TemperatureFactor, TargetNullValue='1.00'}" Padding="5,0" VerticalContentAlignment="Center" Margin="2"/>
                            <TextBlock Grid.Row="3" Grid.Column="2" Text="—" Margin="5,0" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Thanh Trạng Thái -->
            <StatusBar Grid.Row="4" Background="#F8F9F9" BorderBrush="#D5DBDB" BorderThickness="0,1,0,0">
                <StatusBarItem Content="Ván khuôn sàn"/>
                <Separator/>
                <StatusBarItem Content="{Binding RevitVersionStatus}"/>
            </StatusBar>
        </Grid>
    </Grid>
</UserControl>

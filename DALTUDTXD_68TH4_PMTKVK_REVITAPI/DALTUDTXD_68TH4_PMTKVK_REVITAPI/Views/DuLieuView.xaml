<UserControl x:Class="DALTUDTXD_68TH4_PMTKVK_REVITAPI.Views.DuLieuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DALTUDTXD_68TH4_PMTKVK_REVITAPI.Views"
             xmlns:vm="clr-namespace:DALTUDTXD_68TH4_PMTKVK_REVITAPI.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance Type=vm:DuLieuViewModel, IsDesignTimeCreatable=False}">
    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="25"/>
                <RowDefinition Height="35"/>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>

            <!-- Menu Hệ Thống -->
            <Menu Grid.Row="0" Background="#F3F3F3" Foreground="Black">
                <MenuItem Header=""/>
            </Menu>

            <!-- Tab Navigation -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Background="White">
                <Button Content="Dữ liệu"   Command="{Binding ChangeTabCommand}" CommandParameter="DuLieuView"  Padding="15,0" Background="White" BorderThickness="0,0,1,0" BorderBrush="#EEE" FontWeight="Bold"/>
                <Button Content="Tính toán"  Command="{Binding ChangeTabCommand}" CommandParameter="TinhToanView" Padding="15,0" Background="White" BorderThickness="0,0,1,0" BorderBrush="#EEE"/>
                <Button Content="Thông số"   Command="{Binding ChangeTabCommand}" CommandParameter="ThongSoView"  Padding="15,0" Background="White" BorderThickness="0,0,1,0" BorderBrush="#EEE"/>
                <Button Content="Kết quả"    Command="{Binding ChangeTabCommand}" CommandParameter="KetQuaView"   Padding="15,0" Background="White" BorderThickness="0,0,1,0" BorderBrush="#EEE"/>
            </StackPanel>
            <!-- Toolbar Tính Toán -->
            <Grid Grid.Row="2" Background="#F8F9F9">
                <StackPanel Orientation="Horizontal">
                    <Button Content="Chạy phân tích"        Command="{Binding RunAnalysisCommand}"        Margin="5" Padding="16,5" Background="White" BorderBrush="White" FontWeight="Bold"/>
                    <Button Content="Chọn sàn từ Revit"     Command="{Binding SelectSlabCommand}" Margin="5" Padding="16,5" Background="White" BorderBrush="White" FontWeight="Bold"/>
                </StackPanel>
            </Grid>

            <!-- Vùng Hiển Thị Chính -->
            <Grid Grid.Row="3" Margin="15,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="380"/>
                </Grid.ColumnDefinitions>
                <!-- Bảng Kết Quả -->
                <Border Grid.Column="0" BorderBrush="#ABB2B9" BorderThickness="1" CornerRadius="3" Background="White" Padding="15" Margin="0,0,5,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="BẢNG TỔNG HỢP KIỂM TRA ĐIỀU KIỆN KỸ THUẬT" Foreground="#2C3E50" FontWeight="Bold" FontSize="14" Margin="0,0,0,15"/>

                        <DataGrid ItemsSource="{Binding CheckResults}" 
                      AutoGenerateColumns="False" 
                      CanUserAddRows="False" 
                      IsReadOnly="True"
                      Background="White" 
                      RowHeight="30"
                      BorderThickness="1" 
                      BorderBrush="#D5DBDB">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Nội dung kiểm tra" Binding="{Binding NoiDungKiemTra}"  Width="*"/>
                                <DataGridTextColumn Header="Thực tế"           Binding="{Binding GiaTriThucTe}"   Width="90"/>
                                <DataGridTextColumn Header="Cho phép"          Binding="{Binding GiaTriChoPhep}"   Width="90"/>
                                <DataGridTemplateColumn Header="Kết luận" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding MauNenTrangThai}" CornerRadius="2" Margin="2">
                                                <TextBlock Text="{Binding KetLuan}" 
                                               Foreground="{Binding MauChuTrangThai}"
                                               FontWeight="Bold" 
                                               HorizontalAlignment="Center" 
                                               VerticalAlignment="Center"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

                <!-- Các Thông Số Đầu Vào -->
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Margin="5,0,0,0">
                    <StackPanel>
                        <!-- Thông Số Vật Liệu -->
                        <Border BorderBrush="#ABB2B9" BorderThickness="1" CornerRadius="3" Background="White" Padding="15" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="THÔNG SỐ VẬT LIỆU" Foreground="#2C3E50" FontWeight="Bold" FontSize="14" Margin="0,0,0,15"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="40"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="35"/>
                                        <RowDefinition Height="35"/>
                                        <RowDefinition Height="35"/>
                                        <RowDefinition Height="35"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Text="Cường độ gỗ uốn (f):" VerticalAlignment="Center"/>
                                    <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding WoodStrength}" Padding="5,0" VerticalContentAlignment="Center" Margin="2"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="MPa" Margin="5,0" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="1" Text="Mô đun đàn hồi (E):" VerticalAlignment="Center"/>
                                    <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding ElasticModulus}" Padding="5,0" VerticalContentAlignment="Center" Margin="2"/>
                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="MPa" Margin="5,0" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="2" Text="Độ võng [f] sàn:" VerticalAlignment="Center"/>
                                    <TextBox   Grid.Row="2" Grid.Column="1" Text="{Binding SlabDeflectionLimit}" Padding="5,0" VerticalContentAlignment="Center" Margin="2"/>
                                    <TextBlock Grid.Row="2" Grid.Column="2" Text="L/n" Margin="5,0" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="3" Text="Độ võng [f] xà gồ:" VerticalAlignment="Center"/>
                                    <TextBox   Grid.Row="3" Grid.Column="1" Text="{Binding JoistDeflectionLimit}" Padding="5,0" VerticalContentAlignment="Center" Margin="2"/>
                                    <TextBlock Grid.Row="3" Grid.Column="2" Text="L/n" Margin="5,0" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Thông Số Tiết Diện -->
                        <Border BorderBrush="#ABB2B9" BorderThickness="1" CornerRadius="3" Background="White" Padding="15" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="THÔNG SỐ TIẾT DIỆN CẤU KIỆN" Foreground="#2C3E50" FontWeight="Bold" FontSize="14" Margin="0,0,0,15"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="40"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="35"/>
                                        <RowDefinition Height="35"/>
                                        <RowDefinition Height="35"/>
                                        <RowDefinition Height="35"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Text="Ván mặt (dày t):" VerticalAlignment="Center"/>
                                    <TextBox   Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding VanMatThickness}" Padding="5,0" VerticalContentAlignment="Center" Margin="2"/>
                                    <TextBlock Grid.Row="0" Grid.Column="3" Text="mm" Margin="5,0" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="1" Text="Xà gồ phụ (b x h):" VerticalAlignment="Center"/>
                                    <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding XaGoPhuWidth}" Padding="5,0" VerticalContentAlignment="Center" Margin="2"/>
                                    <TextBox   Grid.Row="1" Grid.Column="2" Text="{Binding XaGoPhuHeight}" Padding="5,0" VerticalContentAlignment="Center" Margin="2"/>
                                    <TextBlock Grid.Row="1" Grid.Column="3" Text="mm" Margin="5,0" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="2" Text="Xà gồ chính (b x h):" VerticalAlignment="Center"/>
                                    <TextBox   Grid.Row="2" Grid.Column="1" Text="{Binding XaGoChinhWidth}" Padding="5,0" VerticalContentAlignment="Center" Margin="2"/>
                                    <TextBox   Grid.Row="2" Grid.Column="2" Text="{Binding XaGoChinhHeight}" Padding="5,0" VerticalContentAlignment="Center" Margin="2"/>
                                    <TextBlock Grid.Row="2" Grid.Column="3" Text="mm" Margin="5,0" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="3" Text="Cây chống (D x t):" VerticalAlignment="Center"/>
                                    <TextBox   Grid.Row="3" Grid.Column="1" Text="{Binding CayChongDiameter}" Padding="5,0" VerticalContentAlignment="Center" Margin="2"/>
                                    <TextBox   Grid.Row="3" Grid.Column="2" Text="{Binding CayChongThickness}" Padding="5,0" VerticalContentAlignment="Center" Margin="2"/>
                                    <TextBlock Grid.Row="3" Grid.Column="3" Text="mm" Margin="5,0" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Thông Số Bố Trí -->
                        <Border BorderBrush="#ABB2B9" BorderThickness="1" CornerRadius="3" Background="White" Padding="15" Margin="0,0,0,0">
                            <StackPanel>
                                <TextBlock Text="THÔNG SỐ BỐ TRÍ" Foreground="#2C3E50" FontWeight="Bold" FontSize="14" Margin="0,0,0,15"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="40"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="35"/>
                                        <RowDefinition Height="35"/>
                                        <RowDefinition Height="35"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Text="Khoảng cách XG phụ:" VerticalAlignment="Center"/>
                                    <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding Joist1Spacing}" Padding="5,0" VerticalContentAlignment="Center" Margin="2"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="mm" Margin="5,0" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="1" Text="Khoảng cách XG chính:" VerticalAlignment="Center"/>
                                    <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding Joist2Spacing}" Padding="5,0" VerticalContentAlignment="Center" Margin="2"/>
                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="mm" Margin="5,0" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="2" Text="Khoảng cách cây chống:" VerticalAlignment="Center"/>
                                    <TextBox   Grid.Row="2" Grid.Column="1" Text="{Binding SupportSpacing}" Padding="5,0" VerticalContentAlignment="Center" Margin="2"/>
                                    <TextBlock Grid.Row="2" Grid.Column="2" Text="mm" Margin="5,0" VerticalAlignment="Center"/>
                                </Grid>

                                <Separator Margin="0,15"/>

                                <Grid Margin="0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Content="Chọn sàn từ Revit" 
                                    Command="{Binding SelectSlabCommand}"
                                    Height="45" Background="White" Foreground="Black"
                                    FontWeight="Bold"/>
                                    <Button Grid.Column="2" Content="Quét chọn nhiều ô sàn" 
                                    Command="{Binding SweepSelectSlabCommand}"
Height="45" Background="#3498DB" Foreground="White"
                                    FontWeight="Bold"/>
                                </Grid>

                                <Button Content="Cập nhật kết quả" 
                            Command="{Binding UpdateResultsCommand}"
                            Height="45" Background="White" Foreground="Black"
                            FontWeight="Bold" Margin="0,10"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Thanh Trạng Thái -->
            <StatusBar Grid.Row="4" Background="#F8F9F9" BorderBrush="#D5DBDB" BorderThickness="0,1,0,0">
                <StatusBarItem Content="Ván khuôn sàn"/>
                <Separator/>
                <StatusBarItem Content="{Binding RevitVersionStatus}"/>
            </StatusBar>
        </Grid>
    </Grid>
</UserControl>
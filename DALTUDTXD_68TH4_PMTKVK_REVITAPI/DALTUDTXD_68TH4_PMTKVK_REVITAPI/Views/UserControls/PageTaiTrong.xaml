<UserControl x:Class="DALTUDTXD_68TH4_PMTKVK_REVITAPI.Views.UserControls.PageTaiTrong"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DALTUDTXD_68TH4_PMTKVK_REVITAPI.Views.UserControls"
             Height="650" Width="1050"
             Background="SteelBlue" FontFamily="Segoe UI" FontSize="12">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="25"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>
        <Menu Grid.Row="0" Background="#F3F3F3" Foreground="Black">
            <MenuItem Header="Hệ thống"/>
            <MenuItem Header="Dữ liệu Revit"/>
            <MenuItem Header="Tính toán"/>
            <MenuItem Header="Trợ giúp"/>
        </Menu>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Background="White">
            <Button x:Name="btnTabTep" Content="Dự án" Click="Tab_Click" Padding="15,0" Background="Transparent" BorderThickness="0,0,1,0" BorderBrush="#EEE"/>
            <Button x:Name="btnTabNhapLieu" Content="Chọn cấu kiện" Click="Tab_Click" Padding="15,0" Background="Transparent" BorderThickness="0,0,1,0" BorderBrush="#EEE"/>
            <Button x:Name="btnTabTaiTrong" Content="Tải trọng" Click="Tab_Click" Padding="15,0" Background="#D6EAF8" BorderThickness="0,0,1,0" BorderBrush="#EEE" FontWeight="Bold"/>
            <Button x:Name="btnTabKiemTra" Content="Kiểm tra" Click="Tab_Click" Padding="15,0" Background="Transparent" BorderThickness="0,0,1,0" BorderBrush="#EEE"/>
            <Button x:Name="btnTabBaoCao" Content="Thống kê" Click="Tab_Click" Padding="15,0" Background="Transparent" BorderThickness="0,0,1,0" BorderBrush="#EEE"/>
        </StackPanel>
        <Grid Grid.Row="2" Background="#F8F9F9">
            <StackPanel x:Name="panelTaiTrong" Orientation="Horizontal" Visibility="Visible">
                <Button Content=" Thông số tải trọng" Margin="5" Padding="10,5" Background="White" BorderBrush="#D5DBDB"/>
                <Button Content=" Hệ số tin cậy" Margin="5" Padding="10,5" Background="White" BorderBrush="#D5DBDB"/>
                <Button Content=" Tổ hợp tải trọng (TCVN)" Margin="5" Padding="10,5" Background="White" BorderBrush="#D5DBDB" Foreground="DarkRed"/>
            </StackPanel>
            <StackPanel x:Name="panelTep" Orientation="Horizontal" Visibility="Collapsed">
                <Button Content=" Thiết lập dự án" Margin="5" Padding="10,5" Background="White" BorderBrush="#D5DBDB"/>
            </StackPanel>
        </Grid>
        <Grid Grid.Row="3" Margin="15,10" Background="#EBEDEF">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="400"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" BorderBrush="DimGray" BorderThickness="1" CornerRadius="3" Background="White" Padding="15" Margin="0,0,5,0">
                <StackPanel>
                    <TextBlock Text="THÔNG SỐ TẢI TRỌNG THIẾT KẾ" Foreground="#2E86C1" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                        </Grid.RowDefinitions>

                    </Grid>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" BorderBrush="DimGray" BorderThickness="1" CornerRadius="3" Background="White" Padding="15" Margin="5,0,0,0">
                <StackPanel>
                    <TextBlock Text="HÌNH THỨC TÍNH TOÁN" Foreground="#2E86C1" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                    <RadioButton Content="Tính toán theo Trạng thái giới hạn I (Cường độ)" IsChecked="True" Margin="0,5"/>
                    <RadioButton Content="Tính toán theo Trạng thái giới hạn II (Độ võng)" Margin="0,5"/>
                    <Separator Margin="0,10"/>
                    <TextBlock Text="Ghi chú:" FontWeight="Bold" Margin="0,5"/>
                    <TextBlock TextWrapping="Wrap" Foreground="DimGray" Text="Các thông số tải trọng được áp dụng theo TCVN 4453:1995 về thi công và nghiệm thu công tác bê tông cốt thép toàn khối."/>
                </StackPanel>
            </Border>
        </Grid>
        <StatusBar Grid.Row="4" Background="SteelBlue" Foreground="White">
            <StatusBarItem Content="Load Parameters: Updated"/>
            <Separator/>
            <StatusBarItem Content="..."/>
        </StatusBar>
    </Grid>
</UserControl>

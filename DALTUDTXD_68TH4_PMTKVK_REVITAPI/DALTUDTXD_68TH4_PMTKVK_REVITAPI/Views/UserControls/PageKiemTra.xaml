<UserControl x:Class="DALTUDTXD_68TH4_PMTKVK_REVITAPI.Views.UserControls.PageKiemTra"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DALTUDTXD_68TH4_PMTKVK_REVITAPI.Views.UserControls"
             mc:Ignorable="d" 
                         d:DesignHeight="450" d:DesignWidth="800" Background="SteelBlue" FontFamily="Segoe UI" FontSize="12">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="25"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>
        <Menu Grid.Row="0" Background="#F3F3F3" Foreground="Black">
            <MenuItem Header="Hệ thống"/>
            <MenuItem Header="Dữ liệu Revit"/>
            <MenuItem Header="Tính toán"/>
            <MenuItem Header="Trợ giúp"/>
        </Menu>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Background="White">
            <Button x:Name="btnTabTep" Content="Dự án" Click="Tab_Click" Padding="15,0" Background="Transparent" BorderThickness="0,0,1,0" BorderBrush="#EEE"/>
            <Button x:Name="btnTabNhapLieu" Content="Chọn cấu kiện" Click="Tab_Click" Padding="15,0" Background="Transparent" BorderThickness="0,0,1,0" BorderBrush="#EEE"/>
            <Button x:Name="btnTabTaiTrong" Content="Tải trọng" Click="Tab_Click" Padding="15,0" Background="Transparent" BorderThickness="0,0,1,0" BorderBrush="#EEE"/>
            <Button x:Name="btnTabKiemTra" Content="Kiểm tra" Click="Tab_Click" Padding="15,0" Background="#D6EAF8" BorderThickness="0,0,1,0" BorderBrush="#EEE" FontWeight="Bold"/>
            <Button x:Name="btnTabBaoCao" Content="Thống kê" Click="Tab_Click" Padding="15,0" Background="Transparent" BorderThickness="0,0,1,0" BorderBrush="#EEE"/>
        </StackPanel>
        <Grid Grid.Row="2" Background="#F8F9F9">
            <StackPanel x:Name="panelKiemTra" Orientation="Horizontal" Visibility="Visible">
                <Button Content=" Chạy phân tích" Margin="5" Padding="10,5" Background="#E74C3C" Foreground="White" FontWeight="Bold"/>
                <Button Content=" Xem biểu đồ nội lực" Margin="5" Padding="10,5" Background="White" BorderBrush="#D5DBDB"/>
                <Button Content=" Tối ưu hóa bước xà gồ" Margin="5" Padding="10,5" Background="White" BorderBrush="#D5DBDB"/>
            </StackPanel>
        </Grid>
        <Grid Grid.Row="3" Margin="15,10" Background="#EBEDEF">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" BorderBrush="DimGray" BorderThickness="1" CornerRadius="3" Background="White" Padding="15" Margin="0,0,5,0">
                <StackPanel>
                    <TextBlock Text="BẢNG TỔNG HỢP KIỂM TRA ĐIỀU KIỆN KỸ THUẬT" Foreground="#2E86C1" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                    <DataGrid x:Name="dgCheckResults" Background="White" BorderThickness="1" BorderBrush="#DDD" AutoGenerateColumns="False" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Cấu kiện" Binding="{Binding Component}" Width="100"/>
                            <DataGridTextColumn Header="Nội dung kiểm tra" Binding="{Binding CheckContent}" Width="*"/>
                            <DataGridTextColumn Header="Thực tế" Binding="{Binding ActualValue}" Width="80"/>
                            <DataGridTextColumn Header="Cho phép" Binding="{Binding AllowValue}" Width="80"/>
                            <DataGridTemplateColumn Header="Kết luận" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Status}" Foreground="{Binding StatusColor}" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" BorderBrush="DimGray" BorderThickness="1" CornerRadius="3" Background="White" Padding="15" Margin="5,0,0,0">
                <StackPanel>
                    <TextBlock Text="THÔNG SỐ VẬT LIỆU" Foreground="#2E86C1" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Cường độ gỗ uốn (f):" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="14.5" Margin="2" VerticalContentAlignment="Center"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="MPa" Margin="5,0" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="1" Text="Mô đun đàn hồi (E):" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="10000" Margin="2" VerticalContentAlignment="Center"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="MPa" Margin="5,0" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="2" Text="Độ võng [f] sàn:" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="L/400" Margin="2" VerticalContentAlignment="Center"/>
                        <TextBlock Grid.Row="3" Text="Độ võng [f] xà gồ:" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="3" Grid.Column="1" Text="L/500" Margin="2" VerticalContentAlignment="Center"/>
                    </Grid>
                    <Separator Margin="0,15"/>
                    <Button Content="CẬP NHẬT KẾT QUẢ" Height="40" Background="SteelBlue" Foreground="White" FontWeight="Bold" Margin="0,10"/>
                    <TextBlock Text="* Lưu ý: Kết quả được tính toán dựa trên sơ đồ dầm liên tục nhiều nhịp." 
FontStyle="Italic" Foreground="Gray" TextWrapping="Wrap" FontSize="11"/>
                </StackPanel>
            </Border>
        </Grid>
        <StatusBar Grid.Row="4" Background="SteelBlue" Foreground="White">
            <StatusBarItem Content="Analysis State: Complete"/>
            <Separator/>
            <StatusBarItem Content="Bùi Thành Kiệt - 68TH4 - HUCE"/>
        </StatusBar>
    </Grid>

</UserControl>

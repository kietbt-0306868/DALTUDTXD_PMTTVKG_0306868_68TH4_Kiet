<UserControl x:Class="DALTUDTXD_68TH4_PMTKVK_REVITAPI.Views.TinhToanView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DALTUDTXD_68TH4_PMTKVK_REVITAPI.Views"
             xmlns:vm="clr-namespace:DALTUDTXD_68TH4_PMTKVK_REVITAPI.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="550" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance Type=vm:TinhToanViewModel, IsDesignTimeCreatable=False}">
    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="25"/>
                <RowDefinition Height="35"/>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>

            <!-- Menu Hệ Thống -->
            <Menu Grid.Row="0" Background="#F3F3F3" Foreground="Black">
                <MenuItem Header=""/>
            </Menu>
            
            <!-- Tab Navigation -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Background="White">
                <Button Content="Dữ liệu"     Command="{Binding ChangeTabCommand}" CommandParameter="DuLieuView"  Padding="15,0" Background="White" BorderThickness="0,0,1,0" BorderBrush="#EEE"/>
                <Button Content="Tính toán"   Command="{Binding ChangeTabCommand}" CommandParameter="TinhToanView" Padding="15,0" Background="White" BorderThickness="0,0,1,0" BorderBrush="#EEE" FontWeight="Bold"/>
                <Button Content="Thông số"   Command="{Binding ChangeTabCommand}" CommandParameter="ThongSoView"  Padding="15,0" Background="White" BorderThickness="0,0,1,0" BorderBrush="#EEE"/>
                <Button Content="Kết quả"     Command="{Binding ChangeTabCommand}" CommandParameter="KetQuaView"   Padding="15,0" Background="White" BorderThickness="0,0,1,0" BorderBrush="#EEE"/>
            </StackPanel>
            
            <!-- Toolbar Tính Toán -->
            <Grid Grid.Row="2" Background="#F8F9F9">
                <StackPanel Orientation="Horizontal">
                    <Button Content=" Chạy tính toán lại"        Command="{Binding RecalculateCommand}"        Margin="5" Padding="12,5" Background="White" BorderBrush="White" FontWeight="Bold"/>
                </StackPanel>
            </Grid>

            <!-- Vùng Hiển Thị Chính -->
            <Grid Grid.Row="3" Margin="15,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Banner trạng thái tổng thể -->
                <Border Grid.Row="0" Margin="0,0,0,10" CornerRadius="3" Padding="12" 
                        Background="{Binding IsSystemSafeColor, TargetNullValue='#D1FAE5'}" 
                        BorderBrush="{Binding IsSystemSafeBorderColor, TargetNullValue='#10B981'}" 
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Path Grid.Column="0" Width="20" Height="20" Stretch="Uniform" Fill="{Binding IsSystemSafeIconColor, TargetNullValue='#10B981'}" Data="M12,2C6.48,2 2,6.48 2,12C2,17.52 6.48,22 12,22C17.52,22 22,17.52 22,12C22,6.48 17.52,2 12,2ZM10,17L5,12L6.41,10.59L10,14.17L17.59,6.58L19,8L10,17Z" Margin="0,0,10,0"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding SystemSafeTitle, TargetNullValue='HỆ THỐNG ĐẠT YÊU CẦU AN TOÀN KỸ THUẬT'}" FontSize="12" FontWeight="Bold" Foreground="{Binding IsSystemSafeTextColor, TargetNullValue='#065F46'}"/>
                            <TextBlock Text="{Binding SystemSafeDescription, TargetNullValue='Tất cả các cấu kiện (ván mặt, xà gồ phụ, xà gồ chính, cây chống) đều thoả mãn điều kiện cường độ và độ võng.'}" FontSize="11" Foreground="{Binding IsSystemSafeTextColor, TargetNullValue='#065F46'}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Chi tiết kiểm tra từng cấu kiện -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- CARD 1: VÁN MẶT -->
                        <Border Grid.Row="0" Grid.Column="0" Background="White" Margin="0,5,5,5" CornerRadius="3" Padding="15" BorderBrush="#ABB2B9" BorderThickness="1">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="VÁN MẶT (PLYWOOD)" FontWeight="Bold" FontSize="13" Foreground="#2C3E50"/>
                                    <Border Background="{Binding PlywoodStatusColor, TargetNullValue='#D1FAE5'}" CornerRadius="2" Padding="6,2" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding PlywoodStatusText, TargetNullValue='ĐẠT'}" Foreground="{Binding PlywoodStatusTextColor, TargetNullValue='#065F46'}" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                </DockPanel>
                                
                                <Separator Background="#EEE" Margin="0,5,0,10"/>
                                
                                <!-- Kiểm tra ứng suất uốn -->
                                <TextBlock Text="Ứng suất uốn (σ)" FontSize="11" Foreground="#7F8C8D"/>
                                <Grid Margin="0,2,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" Grid.Column="0">
                                        <TextBlock Text="{Binding PlywoodStressActual, TargetNullValue='8.45'}" FontWeight="SemiBold" FontSize="13" Foreground="{Binding PlywoodStressTextColor, TargetNullValue='#2C3E50'}"/>
                                        <TextBlock Text=" MPa / " FontSize="11" Foreground="#7F8C8D" VerticalAlignment="Bottom"/>
                                        <TextBlock Text="{Binding PlywoodStressLimit, TargetNullValue='15.00'}" FontSize="11" Foreground="#7F8C8D" VerticalAlignment="Bottom"/>
                                        <TextBlock Text=" MPa" FontSize="11" Foreground="#7F8C8D" VerticalAlignment="Bottom"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="σ ≤ [Ru]" FontSize="10" FontStyle="Italic" Foreground="{Binding PlywoodStressTextColor, TargetNullValue='#BDC3C7'}" VerticalAlignment="Center"/>
                                </Grid>
                                <ProgressBar Value="{Binding PlywoodStressRatio, TargetNullValue='56.3'}" Height="5" Background="#E2E8F0" Foreground="{Binding PlywoodStressColor, TargetNullValue='#10B981'}" Margin="0,0,0,15"/>

                                <!-- Kiểm tra độ võng -->
                                <TextBlock Text="Độ võng thực tế (f_tt)" FontSize="11" Foreground="#7F8C8D"/>
                                <Grid Margin="0,2,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" Grid.Column="0">
                                        <TextBlock Text="{Binding PlywoodDeflectionActual, TargetNullValue='1.12'}" FontWeight="SemiBold" FontSize="13" Foreground="{Binding PlywoodDeflectionTextColor, TargetNullValue='#2C3E50'}"/>
                                        <TextBlock Text=" mm / " FontSize="11" Foreground="#7F8C8D" VerticalAlignment="Bottom"/>
                                        <TextBlock Text="{Binding PlywoodDeflectionLimit, TargetNullValue='2.00'}" FontSize="11" Foreground="#7F8C8D" VerticalAlignment="Bottom"/>
                                        <TextBlock Text=" mm" FontSize="11" Foreground="#7F8C8D" VerticalAlignment="Bottom"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="f_tt ≤ [f]" FontSize="10" FontStyle="Italic" Foreground="{Binding PlywoodDeflectionTextColor, TargetNullValue='#BDC3C7'}" VerticalAlignment="Center"/>
                                </Grid>
                                <ProgressBar Value="{Binding PlywoodDeflectionRatio, TargetNullValue='56.0'}" Height="5" Background="#E2E8F0" Foreground="{Binding PlywoodDeflectionColor, TargetNullValue='#10B981'}"/>
                            </StackPanel>
                        </Border>

                        <!-- CARD 2: XÀ GỒ PHỤ (LỚP 1) -->
                        <Border Grid.Row="0" Grid.Column="1" Background="White" Margin="5,5,0,5" CornerRadius="3" Padding="15" BorderBrush="#ABB2B9" BorderThickness="1">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="XÀ GỒ LỚP 1 (THANH PHỤ)" FontWeight="Bold" FontSize="13" Foreground="#2C3E50"/>
                                    <Border Background="{Binding Joist1StatusColor, TargetNullValue='#D1FAE5'}" CornerRadius="2" Padding="6,2" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding Joist1StatusText, TargetNullValue='ĐẠT'}" Foreground="{Binding Joist1StatusTextColor, TargetNullValue='#065F46'}" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                </DockPanel>
                                
                                <Separator Background="#EEE" Margin="0,5,0,10"/>
                                
                                <!-- Ứng suất uốn -->
                                <TextBlock Text="Ứng suất uốn (σ)" FontSize="11" Foreground="#7F8C8D"/>
                                <Grid Margin="0,2,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" Grid.Column="0">
                                        <TextBlock Text="{Binding Joist1StressActual, TargetNullValue='10.12'}" FontWeight="SemiBold" FontSize="13" Foreground="{Binding Joist1StressTextColor, TargetNullValue='#2C3E50'}"/>
                                        <TextBlock Text=" MPa / " FontSize="11" Foreground="#7F8C8D" VerticalAlignment="Bottom"/>
                                        <TextBlock Text="{Binding Joist1StressLimit, TargetNullValue='13.00'}" FontSize="11" Foreground="#7F8C8D" VerticalAlignment="Bottom"/>
                                        <TextBlock Text=" MPa" FontSize="11" Foreground="#7F8C8D" VerticalAlignment="Bottom"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="σ ≤ [Ru]" FontSize="10" FontStyle="Italic" Foreground="{Binding Joist1StressTextColor, TargetNullValue='#BDC3C7'}" VerticalAlignment="Center"/>
                                </Grid>
                                <ProgressBar Value="{Binding Joist1StressRatio, TargetNullValue='77.8'}" Height="5" Background="#E2E8F0" Foreground="{Binding Joist1StressColor, TargetNullValue='#10B981'}" Margin="0,0,0,15"/>

                                <!-- Độ võng -->
                                <TextBlock Text="Độ võng thực tế (f_tt)" FontSize="11" Foreground="#7F8C8D"/>
                                <Grid Margin="0,2,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" Grid.Column="0">
                                        <TextBlock Text="{Binding Joist1DeflectionActual, TargetNullValue='2.14'}" FontWeight="SemiBold" FontSize="13" Foreground="{Binding Joist1DeflectionTextColor, TargetNullValue='#2C3E50'}"/>
                                        <TextBlock Text=" mm / " FontSize="11" Foreground="#7F8C8D" VerticalAlignment="Bottom"/>
                                        <TextBlock Text="{Binding Joist1DeflectionLimit, TargetNullValue='3.00'}" FontSize="11" Foreground="#7F8C8D" VerticalAlignment="Bottom"/>
                                        <TextBlock Text=" mm" FontSize="11" Foreground="#7F8C8D" VerticalAlignment="Bottom"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="f_tt ≤ [f]" FontSize="10" FontStyle="Italic" Foreground="{Binding Joist1DeflectionTextColor, TargetNullValue='#BDC3C7'}" VerticalAlignment="Center"/>
                                </Grid>
                                <ProgressBar Value="{Binding Joist1DeflectionRatio, TargetNullValue='71.3'}" Height="5" Background="#E2E8F0" Foreground="{Binding Joist1DeflectionColor, TargetNullValue='#10B981'}"/>
                            </StackPanel>
                        </Border>

                        <!-- CARD 3: XÀ GỒ CHÍNH (LỚP 2) -->
                        <Border Grid.Row="1" Grid.Column="0" Background="White" Margin="0,5,5,5" CornerRadius="3" Padding="15" BorderBrush="#ABB2B9" BorderThickness="1">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="XÀ GỒ LỚP 2 (THANH CHÍNH)" FontWeight="Bold" FontSize="13" Foreground="#2C3E50"/>
                                    <Border Background="{Binding Joist2StatusColor, TargetNullValue='#FEE2E2'}" CornerRadius="2" Padding="6,2" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding Joist2StatusText, TargetNullValue='KHÔNG ĐẠT'}" Foreground="{Binding Joist2StatusTextColor, TargetNullValue='#991B1B'}" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                </DockPanel>
                                
                                <Separator Background="#EEE" Margin="0,5,0,10"/>
                                
                                <!-- Ứng suất uốn -->
                                <TextBlock Text="Ứng suất uốn (σ)" FontSize="11" Foreground="#7F8C8D"/>
                                <Grid Margin="0,2,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" Grid.Column="0">
                                        <TextBlock Text="{Binding Joist2StressActual, TargetNullValue='11.50'}" FontWeight="SemiBold" FontSize="13" Foreground="{Binding Joist2StressTextColor, TargetNullValue='#2C3E50'}"/>
                                        <TextBlock Text=" MPa / " FontSize="11" Foreground="#7F8C8D" VerticalAlignment="Bottom"/>
                                        <TextBlock Text="{Binding Joist2StressLimit, TargetNullValue='13.00'}" FontSize="11" Foreground="#7F8C8D" VerticalAlignment="Bottom"/>
                                        <TextBlock Text=" MPa" FontSize="11" Foreground="#7F8C8D" VerticalAlignment="Bottom"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="σ ≤ [Ru]" FontSize="10" FontStyle="Italic" Foreground="{Binding Joist2StressTextColor, TargetNullValue='#BDC3C7'}" VerticalAlignment="Center"/>
                                </Grid>
                                <ProgressBar Value="{Binding Joist2StressRatio, TargetNullValue='88.5'}" Height="5" Background="#E2E8F0" Foreground="{Binding Joist2StressColor, TargetNullValue='#10B981'}" Margin="0,0,0,15"/>

                                <!-- Độ võng -->
                                <TextBlock Text="Độ võng thực tế (f_tt)" FontSize="11" Foreground="#7F8C8D"/>
                                <Grid Margin="0,2,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" Grid.Column="0">
                                        <TextBlock Text="{Binding Joist2DeflectionActual, TargetNullValue='4.25'}" FontWeight="SemiBold" FontSize="13" Foreground="{Binding Joist2DeflectionTextColor, TargetNullValue='#2C3E50'}"/>
                                        <TextBlock Text=" mm / " FontSize="11" Foreground="#7F8C8D" VerticalAlignment="Bottom"/>
                                        <TextBlock Text="{Binding Joist2DeflectionLimit, TargetNullValue='4.00'}" FontSize="11" Foreground="#7F8C8D" VerticalAlignment="Bottom"/>
                                        <TextBlock Text=" mm" FontSize="11" Foreground="#7F8C8D" VerticalAlignment="Bottom"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="f_tt ≤ [f]" FontSize="10" FontStyle="Italic" Foreground="{Binding Joist2DeflectionTextColor, TargetNullValue='#BDC3C7'}" VerticalAlignment="Center"/>
                                </Grid>
                                <ProgressBar Value="{Binding Joist2DeflectionRatio, TargetNullValue='106.2'}" Height="5" Background="#E2E8F0" Foreground="{Binding Joist2DeflectionColor, TargetNullValue='#10B981'}"/>
                            </StackPanel>
                        </Border>

                        <!-- CARD 4: HỆ CÂY CHỐNG -->
                        <Border Grid.Row="1" Grid.Column="1" Background="White" Margin="5,5,0,5" CornerRadius="3" Padding="15" BorderBrush="#ABB2B9" BorderThickness="1">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="HỆ CÂY CHỐNG ĐỨNG" FontWeight="Bold" FontSize="13" Foreground="#2C3E50"/>
                                    <Border Background="{Binding SupportStatusColor, TargetNullValue='#D1FAE5'}" CornerRadius="2" Padding="6,2" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding SupportStatusText, TargetNullValue='ĐẠT'}" Foreground="{Binding SupportStatusTextColor, TargetNullValue='#065F46'}" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                </DockPanel>
                                
                                <Separator Background="#EEE" Margin="0,5,0,10"/>
                                
                                <!-- Lực dọc trục tác dụng -->
                                <TextBlock Text="Lực dọc trục lên đầu cột (P_tt)" FontSize="11" Foreground="#7F8C8D"/>
                                <Grid Margin="0,2,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" Grid.Column="0">
                                        <TextBlock Text="{Binding SupportLoadActual, TargetNullValue='15.40'}" FontWeight="SemiBold" FontSize="13" Foreground="{Binding SupportLoadTextColor, TargetNullValue='#2C3E50'}"/>
                                        <TextBlock Text=" kN / " FontSize="11" Foreground="#7F8C8D" VerticalAlignment="Bottom"/>
                                        <TextBlock Text="{Binding SupportLoadLimit, TargetNullValue='25.00'}" FontSize="11" Foreground="#7F8C8D" VerticalAlignment="Bottom"/>
                                        <TextBlock Text=" kN" FontSize="11" Foreground="#7F8C8D" VerticalAlignment="Bottom"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="P_tt ≤ [Pcp]" FontSize="10" FontStyle="Italic" Foreground="{Binding SupportLoadTextColor, TargetNullValue='#BDC3C7'}" VerticalAlignment="Center"/>
                                </Grid>
                                <ProgressBar Value="{Binding SupportLoadRatio, TargetNullValue='61.6'}" Height="5" Background="#E2E8F0" Foreground="{Binding SupportLoadColor, TargetNullValue='#10B981'}" Margin="0,0,0,15"/>
                                
                                <!-- Sức chịu tải ổn định của cột -->
                                <Grid Margin="0,5,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Hệ số uốn dọc φ:" FontSize="11" Foreground="#7F8C8D"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SupportSlendernessFactor, TargetNullValue='0.78'}" FontWeight="SemiBold" FontSize="11" Foreground="#2C3E50"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </Grid>

            <!-- Thanh Trạng Thái -->
            <StatusBar Grid.Row="4" Background="#F8F9F9" BorderBrush="#D5DBDB" BorderThickness="0,1,0,0">
                <StatusBarItem Content="Ván khuôn sàn"/>
                <Separator/>
                <StatusBarItem Content="{Binding RevitVersionStatus}"/>
            </StatusBar>
        </Grid>
    </Grid>
</UserControl>
